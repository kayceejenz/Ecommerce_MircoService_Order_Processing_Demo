{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "OrderService": "Debug",
      "MassTransit": "Information"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "OrderReadDb": "Host=localhost;Database=order_read_db;Username=postgres;Password=postgres",
    "SagaStateDb": "Host=localhost;Database=saga_state_db;Username=postgres;Password=postgres",
    "EventStore": "esdb://localhost:2113?tls=false"
  },

  "RabbitMQ": {
    "Host": "localhost"
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  }
}
